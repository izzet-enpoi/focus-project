{
  "manifest_version": 3,
  "name": "Focus Project",
  "version": "1.0.0",
  "description": "Group your tabs by project. Switch projects and the right tabs open while the rest close.",
  "permissions": ["tabs", "storage", "sidePanel"],
  "action": {
    "default_title": "Toggle Focus Project",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
